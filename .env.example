# --- SSH MCP server configuration ---------------------------------------
# Copy to .env and fill in. All values are read at server startup.

# Write mode. When false (default) the ssh_send_config tool is NOT registered
# and the agent cannot make configuration changes. Set to true to enable it.
SSH_MCP_ENABLE_WRITE=false

# --- credentials ---------------------------------------------------------
# A profile needs a username plus a password and/or a private key.
#
# Option A: a single "default" profile via shorthand env vars.
SSH_MCP_USERNAME=netadmin
# Password auth — leave empty for key-only authentication.
SSH_MCP_PASSWORD=changeme
# Optional enable/privileged-exec secret for Cisco-style devices.
SSH_MCP_ENABLE_SECRET=
# Key auth: path to a private key file (~ is expanded). Used instead of or
# alongside the password.
SSH_MCP_PRIVATE_KEY=
# Passphrase for an encrypted private key (omit for an unencrypted key).
SSH_MCP_PRIVATE_KEY_PASSPHRASE=

# Option B: multiple named profiles as JSON (overrides A for any named key).
# Each profile takes username, and password and/or private_key, plus optional
# private_key_passphrase and enable_secret. The agent selects one by name via
# the credential_profile tool argument.
# SSH_MCP_CREDENTIALS={"default":{"username":"netadmin","password":"..."},"keyauth":{"username":"automation","private_key":"/keys/id_ed25519","private_key_passphrase":"..."}}

# --- host-key verification ----------------------------------------------
# Policy: tofu (default — accept-new: pin a host's key on first connection,
# reject a changed key on later ones), strict (only keys already in the
# file; unknown hosts rejected), or off (no verification).
SSH_MCP_HOST_KEY_POLICY=tofu
# known_hosts file used by tofu/strict. Default: ~/.config/ssh-mcp/known_hosts
SSH_MCP_KNOWN_HOSTS=

# --- connection allowlist -----------------------------------------------
# Optional comma-separated host globs / CIDRs the server may connect to.
# Empty (default) allows any host. Example: *.lab.example.com,10.0.0.0/8
SSH_MCP_ALLOWED_HOSTS=

# --- output cap ----------------------------------------------------------
# Max bytes of device output returned per command (0 disables the cap).
SSH_MCP_MAX_OUTPUT_BYTES=1000000

# --- timeouts (seconds) --------------------------------------------------
SSH_MCP_TIMEOUT_SOCKET=15
SSH_MCP_TIMEOUT_OPS=30

# --- safety --------------------------------------------------------------
# Extra comma-separated regex patterns to reject in the read tools.
SSH_MCP_DENYLIST_EXTRA=

# --- audit logging -------------------------------------------------------
# When set, one JSON record per tool call is written here: timestamp, tool,
# host, platform, credential profile, commands (credentials redacted), and
# outcome. A file path (appended), or the literal 'stderr'. Device output is
# never recorded. Empty (default) disables audit logging.
SSH_MCP_AUDIT_LOG=

# --- transport -----------------------------------------------------------
# stdio (default, for Claude Code / Claude Desktop) or http (deployed).
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Required bearer token when MCP_TRANSPORT=http (not needed for stdio).
SSH_MCP_MCP_AUTH_TOKEN=
